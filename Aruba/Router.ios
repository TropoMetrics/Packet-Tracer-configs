enable
configure terminal
hostname Router-Aruba
no ip domain-lookup
banner motd #Verboden toegang voor onbevoegde!#
line console 0
 exec-timeout 60 0
 logging synchronous
 exit
enable secret class

username user priv 15 password cisc
aaa new-model
aaa authentication login MGT local
aaa authentication enable default enable
line vty 0 4
transport input ssh
login authentication MGT
exec-timeout 60
loggin synchronous
exit
ip domain-name hhs.nl
!crypto key zeroize rsa
crypto key generate rsa
2048

ipv6 unicast-routing

ip access-list extended NAT-ACL
 deny ip any 10.10.80.0 0.0.0.255
 deny 145.34.46.0 0.0.0.3 
 permit ip any

ip nat inside source list NAT-ACL interface GigabitEthernet0/0/1 overload

interface GigabitEthernet0/0/1
description Link to ISP
 ip address 145.34.46.2 255.255.255.252
  ip nat outside
 ipv6 enable
 ipv6 address fe80::31 link-local
 no shutdown
exit

interface GigabitEthernet0/0/0
description Internal Network
 ip address 10.20.10.1 255.255.255.0
  ip nat inside
 ipv6 enable
 ipv6 address 2001:f187:0:2010::1/64
 no shutdown
exit

interface Loopback0
description Management interface
ipv6 enable
 ip address 192.168.254.0 255.255.255.255
 ipv6 address 2001:f187:1:1::0/128
exit

interface Tunnel10
 description GRE Aruba <-> Delft1 (primary)
 ip address 172.16.0.2 255.255.255.252
 ipv6 address 2001:f187:ffff:1::2/64
 tunnel source GigabitEthernet0/0/1
 tunnel destination 145.34.44.2
 tunnel mode gre ip
 no shutdown

interface Tunnel11
 description GRE Aruba <-> Delft2 (backup)
 ip address 172.16.0.6 255.255.255.252
 ipv6 address 2001:f187:ffff:2::2/64
 tunnel source GigabitEthernet0/0/1
 tunnel destination 145.34.44.6
 tunnel mode gre ip
 no shutdown

ip route 0.0.0.0 0.0.0.0 145.34.46.1
ipv6 route ::/0 GigabitEthernet0/0/1 fe80::30
ip route 10.10.80.0 255.255.255.0 Tunnel10 10
ip route 10.10.80.0 255.255.255.0 Tunnel11 20
ipv6 route 2001:f187:0:1080::/64 Tunnel10 10
ipv6 route 2001:f187:0:1080::/64 Tunnel11 20

ip dhcp pool VLAN20-ARUBA
 network 10.20.10.0 255.255.255.0
 default-router 10.20.10.1
 dns-server 8.8.8.8
 domain-name hhs.nl
 lease 7

 ip dhcp excluded-address 10.20.10.1 10.20.10.10

