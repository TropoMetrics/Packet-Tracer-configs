enable
delete vlan.dat


configure terminal
hostname MLS1-Delft
no ip domain-lookup
banner motd #Verboden toegang voor onbevoegde!#
line console 0
 exec-timeout 60 0
 logging synchronous
 exit
enable secret class

username user priv 15 password cisc
aaa new-model
aaa authentication login MGT local
aaa authentication enable default enable
line vty 0 4
transport input ssh
login authentication MGT
exec-timeout 60
loggin synchronous
exit
ip domain-name hhs.nl
!crypto key zeroize rsa
crypto key generate rsa
2048

ip routing  
ipv6 unicast-routing

vlan 110
name Management
exit

vlan 120
name Marketing
exit

vlan 130
name Support
exit

vlan 140
name IT-Dienst
exit

vlan 150
name Application-Development
exit

vlan 160
name Meteo-expertise
exit

vlan 170
name Calcnet
exit

vlan 180
name Intranet
exit

vlan 190
name DMZnet
exit

vlan 191
name External
exit

vlan 192
name Management
exit

vlan 999
name BLACKHOLE
exit

interface vlan 999
shutdown
exit

interface vlan 110
ip access-group VLAN-ISOLATION-V4 in
ipv6 traffic-filter VLAN-ISOLATION-V6 in
 ipv6 enable
 ipv6 address 2001:f187:0:1010::1/64
 ip address 10.10.10.2 255.255.255.0
 standby 110 ip 10.10.10.1
 standby 110 priority 110
 standby 110 preempt
 standby version 2
 standby 110 ipv6 autoconfig
 standby 110 priority 110
 ipv6 ospf 1 area 0
exit

