ipv6 enable
 ipv6 address 2001:f187:0:1070::1/64
 ip address 10.10.70.2 255.255.255.0
 standby 170 ip 10.10.70.1
 standby 170 priority 90
 standby 170 preempt
 standby version 2
 standby 170 ipv6 autoconfig
 standby 170 priority 90
 ipv6 ospf 1 area 0
exit

interface vlan 180
ipv6 enable
 ipv6 address 2001:f187:0:1080::1/64
 ip address 10.10.80.2 255.255.255.0
 standby 180 ip 10.10.80.1
 standby 180 priority 90
 standby 180 preempt
 standby version 2
 standby 180 ipv6 autoconfig
 standby 180 priority 90
 ipv6 ospf 1 area 0
