interface GigabitEthernet1/0/24
description Link to ALS1
switchport
switchport mode trunk
switchport trunk allowed vlan 110,120
no shutdown
exit

interface GigabitEthernet1/0/19
description Link to ALS6
switchport
switchport mode trunk
switchport trunk allowed vlan 170,180,190,191,192
no shutdown
exit

interface GigabitEthernet1/0/1
description Link to Router 1 Delft
 no switchport
 ip address 192.168.0.2 255.255.255.252
 ipv6 enable
 ipv6 ospf 1 area 0
 no shutdown
exit

interface GigabitEthernet1/0/2
description Link to Router 2 Delft
 no switchport
 ip address 192.168.0.6 255.255.255.252
 ipv6 enable
 ipv6 ospf 1 area 0
 no shutdown
exit

interface range GigabitEthernet1/0/3-4
description Etherchannel to MLS 1 Delft
 no switchport
 channel-group 10 mode active
 no shutdown
exit

interface range GigabitEthernet1/0/5-18
switchport mode access
switchport access vlan 999
shutdown
exit

interface Port-channel 10
description Etherchannel ip to MLS 1 Delft
 ip address 192.168.0.21 255.255.255.252
 ipv6 enable
 ipv6 ospf 1 area 0
 no shutdown
exit

interface Loopback0
description Management interface
ipv6 enable
 ip address 192.168.255.50 255.255.255.255
 ipv6 address 2001:f187:0:1::50/128
exit

router ospf 1
 passive-interface default
 no passive-interface GigabitEthernet1/0/1
 no passive-interface GigabitEthernet1/0/2
 no passive-interface Port-channel10
 network 192.168.0.0 0.0.0.3 area 0
 network 192.168.0.4 0.0.0.3 area 0
 network 192.168.0.20 0.0.0.3 area 0
 network 192.168.255.50 0.0.0.0 area 0
 network 10.10.10.0 255.255.255.0 area 0
 network 10.10.20.0 255.255.255.0 area 0
 network 10.10.30.0 255.255.255.0 area 0
 network 10.10.40.0 255.255.255.0 area 0
 network 10.10.50.0 255.255.255.0 area 0
 network 10.10.60.0 255.255.255.0 area 0
 network 10.10.70.0 255.255.255.0 area 0
 network 10.10.80.0 255.255.255.0 area 0
 network 10.10.90.0 255.255.255.0 area 0
 network 10.10.91.0 255.255.255.0 area 0
 network 10.10.92.0 255.255.255.0 area 0
exit

ipv6 router ospf 1
 router-id 192.168.255.50
exit

ip access-list extended VLAN-ISOLATION-V4
 permit ip 10.10.10.0 0.0.0.255 10.10.10.0 0.0.0.255
 permit ip 10.10.20.0 0.0.0.255 10.10.20.0 0.0.0.255
 permit ip 10.10.30.0 0.0.0.255 10.10.30.0 0.0.0.255
 permit ip 10.10.40.0 0.0.0.255 10.10.40.0 0.0.0.255
 permit ip 10.10.50.0 0.0.0.255 10.10.50.0 0.0.0.255
 permit ip 10.10.60.0 0.0.0.255 10.10.60.0 0.0.0.255
 permit ip 10.10.70.0 0.0.0.255 10.10.70.0 0.0.0.255

 permit ip any 10.10.80.0 0.0.0.255

 deny ip any 10.10.10.0 0.0.0.255
 deny ip any 10.10.20.0 0.0.0.255
 deny ip any 10.10.30.0 0.0.0.255
 deny ip any 10.10.40.0 0.0.0.255
 deny ip any 10.10.50.0 0.0.0.255
 deny ip any 10.10.60.0 0.0.0.255
 deny ip any 10.10.70.0 0.0.0.255
 deny ip any 10.20.10.0 0.0.0.255
 deny ip any 10.30.10.0 0.0.0.255

 permit ip any any
exit

ipv6 access-list VLAN-ISOLATION-V6
 permit ipv6 2001:F187:0:1010::/64 2001:F187:0:1010::/64
 permit ipv6 2001:F187:0:1020::/64 2001:F187:0:1020::/64
 permit ipv6 2001:F187:0:1030::/64 2001:F187:0:1030::/64
 permit ipv6 2001:F187:0:1040::/64 2001:F187:0:1040::/64
 permit ipv6 2001:F187:0:1050::/64 2001:F187:0:1050::/64
 permit ipv6 2001:F187:0:1060::/64 2001:F187:0:1060::/64
 permit ipv6 2001:F187:0:1070::/64 2001:F187:0:1070::/64

 permit ipv6 any 2001:F187:0:1080::/64

 deny ipv6 any 2001:F187:0:1010::/64
 deny ipv6 any 2001:F187:0:1020::/64
 deny ipv6 any 2001:F187:0:1030::/64
 deny ipv6 any 2001:F187:0:1040::/64
 deny ipv6 any 2001:F187:0:1050::/64
 deny ipv6 any 2001:F187:0:1060::/64
 deny ipv6 any 2001:F187:0:1070::/64
 deny ipv6 any 2001:F187:0:2010::/64
 deny ipv6 any 2001:F187:0:3010::/64

 permit ipv6 any any
exit