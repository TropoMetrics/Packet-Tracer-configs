enable
delete vlan.dat


configure terminal
hostname MLS2-Delft
no ip domain-lookup
banner motd #Verboden toegang voor onbevoegde!#
line console 0
 exec-timeout 60 0
 logging synchronous
 exit
enable secret class

username user priv 15 password cisc
aaa new-model
aaa authentication login MGT local
aaa authentication enable default enable
line vty 0 4
transport input ssh
login authentication MGT
exec-timeout 60
loggin synchronous
exit
ip domain-name hhs.nl
!crypto key zeroize rsa
crypto key generate rsa
2048

ip routing
ipv6 unicast-routing

vlan 110
name Management
exit

vlan 120
name Marketing
exit

vlan 130
name Support
exit

vlan 140
name IT-Dienst
exit

vlan 150
name Application-Development
exit

vlan 160
name Meteo-expertise
exit

vlan 170
name Calcnet
exit

vlan 180
name Intranet
exit

vlan 190
name DMZnet
exit

vlan 191
name External
exit

vlan 999
name BLACKHOLE
exit

interface vlan 999
shutdown
exit

interface vlan 110
ipv6 enable
 ipv6 address 2001:f187:0:1010::1/64
 ip address 10.10.10.3 255.255.255.0
 standby 110 ip 10.10.10.1
 standby 110 priority 90
 standby 110 preempt
 standby version 2
 standby 110 ipv6 autoconfig
 standby 110 priority 90
exit

interface vlan 120
ipv6 enable
 ipv6 address 2001:f187:0:1020::1/64
 ip address 10.10.20.3 255.255.255.0
 standby 120 ip 10.10.20.1
 standby 120 priority 90
 standby 120 preempt
 standby version 2
 standby 120 ipv6 autoconfig
 standby 120 priority 90
exit

interface vlan 130
ipv6 enable
 ipv6 address 2001:f187:0:1030::1/64
 ip address 10.10.30.3 255.255.255.0
 standby 130 ip 10.10.30.1
 standby 130 priority 90
 standby 130 preempt
 standby version 2
 standby 130 ipv6 autoconfig
 standby 130 priority 90
exit

