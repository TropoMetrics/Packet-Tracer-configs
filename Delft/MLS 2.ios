ipv6 enable
 ipv6 address 2001:f187:0:1040::1/64
 ip address 10.10.40.3 255.255.255.0
 standby 140 ip 10.10.40.1
 standby 140 priority 90
 standby 140 preempt
 standby version 2
 standby 140 ipv6 autoconfig
 standby 140 priority 90
exit

